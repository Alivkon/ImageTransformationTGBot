# Токен бота от @BotFather
BOT_TOKEN=your_bot_token_here

# API-ключ KIE.ai (https://kie.ai/api-key)
KIE_API_KEY=your_kie_api_key_here

# Provider token от BotFather (после подключения ЮKassa через /mybots → Payments → Connect ЮKassa)
YOOKASSA_TOKEN=your_yookassa_provider_token_here

# Ваш Telegram user_id (для уведомлений администратора)
ADMIN_ID=123456789

# Стоимость одной генерации в рублях (копейки для Telegram Payments: 20 руб = 2000)
GENERATION_COST=20

# Минимальная сумма пополнения в рублях
MIN_TOPUP=100

# Путь к файлу базы данных
DB_PATH=data/bot.db

# Количество бесплатных генераций для новых пользователей
FREE_GENERATIONS=1

# YooKassa WebApp (ShopID и секретный ключ из кабинета yookassa.ru → Настройки → API-ключи)
YOOKASSA_SHOP_ID=1325037
YOOKASSA_SECRET_KEY=<secret_key_from_yookassa_dashboard>

# URL сайта для WebApp-страницы оплаты
WEBAPP_URL=https://imagetransformation.ru

# Порт внутреннего веб-сервера
WEB_SERVER_PORT=8080
